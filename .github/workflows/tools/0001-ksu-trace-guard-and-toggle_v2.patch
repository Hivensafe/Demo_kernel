diff --git a/drivers/kernelsu/ksu_trace_guard.h b/drivers/kernelsu/ksu_trace_guard.h
new file mode 100644
index 000000000000..111111111111
--- /dev/null
+++ b/drivers/kernelsu/ksu_trace_guard.h
@@ -0,0 +1,85 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#pragma once
+
+#include <linux/jump_label.h>
+#include <linux/percpu.h>
+#include <linux/preempt.h>
+#include <linux/interrupt.h>
+#include <linux/sched.h>
+#include <linux/pid.h>
+
+/* defined in ksu_trace_toggle.c */
+DECLARE_STATIC_KEY_FALSE(ksu_tp_key);
+DECLARE_PER_CPU(unsigned int, ksu_tp_depth);
+
+static __always_inline bool ksu_tp_on(void)
+{
+	return static_branch_unlikely(&ksu_tp_key);
+}
+
+/* only run in very safe contexts */
+static __always_inline bool ksu_safe_context(void)
+{
+	if (unlikely(system_state != SYSTEM_RUNNING))
+		return false;
+	if (unlikely(in_interrupt()) || unlikely(irqs_disabled()))
+		return false;
+	if (unlikely(current->flags & PF_KTHREAD))
+		return false;
+	if (unlikely(preempt_count()))
+		return false;
+	if (unlikely(!pid_task(find_vpid(1), PIDTYPE_PID)))
+		return false;
+	return true;
+}
+
+/* per-cpu, per-task reentrancy guard */
+static __always_inline bool ksu_trace_enter(void)
+{
+	bool ok = false;
+	preempt_disable();
+	if (__this_cpu_read(ksu_tp_depth) == 0) {
+		__this_cpu_inc(ksu_tp_depth);
+		ok = true;
+	}
+	preempt_enable();
+	return ok;
+}
+
+static __always_inline void ksu_trace_exit(void)
+{
+	preempt_disable();
+	__this_cpu_dec(ksu_tp_depth);
+	preempt_enable();
+}
+
+/* one-liner */
+#define KSU_TRACE_SAFE_CALL(_call)                                      \
+	do {                                                                \
+		if (ksu_tp_on() && ksu_safe_context() && ksu_trace_enter()) {   \
+			_call;                                                      \
+			ksu_trace_exit();                                           \
+		}                                                               \
+	} while (0)
diff --git a/drivers/kernelsu/ksu_trace_toggle.c b/drivers/kernelsu/ksu_trace_toggle.c
new file mode 100644
index 000000000000..222222222222
--- /dev/null
+++ b/drivers/kernelsu/ksu_trace_toggle.c
@@ -0,0 +1,105 @@
+// SPDX-License-Identifier: GPL-2.0
+#include <linux/init.h>
+#include <linux/module.h>
+#include <linux/debugfs.h>
+#include <linux/uaccess.h>
+#include <linux/jump_label.h>
+#include "ksu_trace_guard.h"
+
+/* default OFF even if compiled in */
+DEFINE_STATIC_KEY_FALSE(ksu_tp_key);
+DEFINE_PER_CPU(unsigned int, ksu_tp_depth);
+
+static struct dentry *ksu_dbg_dir;
+static bool enabled_cached;
+
+static ssize_t enable_read(struct file *f, char __user *buf, size_t len, loff_t *ppos)
+{
+	char kbuf[4];
+	int n = scnprintf(kbuf, sizeof(kbuf), "%d\n", enabled_cached ? 1 : 0);
+	return simple_read_from_buffer(buf, len, ppos, kbuf, n);
+}
+
+static ssize_t enable_write(struct file *f, const char __user *buf, size_t len, loff_t *ppos)
+{
+	char kbuf[8];
+	bool want;
+	if (len > sizeof(kbuf) - 1)
+		len = sizeof(kbuf) - 1;
+	if (copy_from_user(kbuf, buf, len))
+		return -EFAULT;
+	kbuf[len] = '\0';
+	want = !!simple_strtoul(kbuf, NULL, 0);
+
+	if (want && !enabled_cached) {
+		static_branch_enable(&ksu_tp_key);
+		enabled_cached = true;
+	} else if (!want && enabled_cached) {
+		static_branch_disable(&ksu_tp_key);
+		enabled_cached = false;
+	}
+	return len;
+}
+
+static const struct file_operations enable_fops = {
+	.owner = THIS_MODULE,
+	.open  = simple_open,
+	.read  = enable_read,
+	.write = enable_write,
+	.llseek = default_llseek,
+};
+
+static int __init ksu_trace_toggle_init(void)
+{
+	ksu_dbg_dir = debugfs_create_dir("ksu_trace", NULL);
+	if (IS_ERR_OR_NULL(ksu_dbg_dir))
+		return 0; /* debugfs missing is fine */
+
+	debugfs_create_file("enable", 0644, ksu_dbg_dir, NULL, &enable_fops);
+	enabled_cached = false; /* stay OFF */
+	return 0;
+}
+late_initcall(ksu_trace_toggle_init);
