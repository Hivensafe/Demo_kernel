diff --git a/drivers/input/input.c b/drivers/input/input.c
index 8c5fdb0f8..1f2a0b7ab 100644
--- a/drivers/input/input.c
+++ b/drivers/input/input.c
@@ -29,6 +29,34 @@
 #include "input-core-private.h"
 #include "input-poller.h"
 
+#if defined(CONFIG_KSU) && defined(CONFIG_KSU_TRACEPOINT_HOOK)
+#include <linux/kernel.h>
+#include <linux/percpu.h>
+#include <linux/preempt.h>
+#include <linux/interrupt.h>
+#include <linux/sched.h>
+#include <linux/sched/task.h>
+#include <linux/pid.h>
+#include <../../drivers/kernelsu/ksu_trace.h>
+
+/* --- KSU trace guard (local TU) --- */
+static DEFINE_PER_CPU(unsigned int, ksu_tp_depth);
+static __always_inline bool ksu_trace_enter(void)
+{
+	bool ok = false;
+	preempt_disable();
+	if (__this_cpu_read(ksu_tp_depth) == 0) {
+		__this_cpu_inc(ksu_tp_depth);
+		ok = true;
+	}
+	preempt_enable();
+	return ok;
+}
+static __always_inline void ksu_trace_exit(void)
+{ preempt_disable(); __this_cpu_dec(ksu_tp_depth); preempt_enable(); }
+static __always_inline bool ksu_runtime_ready(void)
+{ return likely(system_state == SYSTEM_RUNNING) && likely(!in_interrupt()) && likely(!(current->flags & PF_KTHREAD)) && likely(pid_task(find_vpid(1), PIDTYPE_PID)); }
+#endif
+
 MODULE_AUTHOR("Vojtech Pavlik <vojtech@suse.cz>");
 MODULE_DESCRIPTION("Input core");
 MODULE_LICENSE("GPL");
@@ -429,6 +457,13 @@ void input_event(struct input_dev *dev,
 {
 	unsigned long flags;
 
+#if defined(CONFIG_KSU) && defined(CONFIG_KSU_TRACEPOINT_HOOK)
+	/* input_event 可能在中断/软中断上下文触发：严格筛选 */
+	if (likely(ksu_runtime_ready()) && ksu_trace_enter()) {
+		trace_ksu_trace_input_hook(&type, &code, &value);
+		ksu_trace_exit();
+	}
+#endif
 	if (is_event_supported(type, dev->evbit, EV_MAX)) {
 
 		spin_lock_irqsave(&dev->event_lock, flags);
