From 1111111111111111111111111111111111111111 Mon Sep 17 00:00:00 2025
From: Qiudaoyu  <sucisama2888@gmail.com>
Date: Wed, 03 Sep 2025 12:34:56 +0800
Subject: [PATCH] security: Add baseband/bootloader guard LSM for Android 6.6
(OnePlus 13 default list)

Add an in-kernel LSM "baseband_guard" that denies write and destructive
ioctl (BLKDISCARD/BLKSECDISCARD/BLKZEROOUT/BLKPG) operations to critical
baseband/NV and bootloader/AVB partitions by name (/dev/block/by-name/*),
with A/B suffix handling. It also denies user-space passthrough ioctls to
/dev/sg*, /dev/bsg/*, and /dev/nvme*, and (by default) blocks whole-disk
destructive operations. Recovery auto-allow is supported.

Runtime params (cmdline or sysfs):
  baseband_guard.guard_enabled=1|0
  baseband_guard.allow_in_recovery=1|0
  baseband_guard.protect_bootimg=1|0
  baseband_guard.block_wholedisk=1|0

Signed-off-by: Qiudaoyu  <sucisama2888@gmail.com>
---
security/Kconfig                           |  22 +++
security/Makefile                          |   1 +
security/baseband_guard.c                  | 323 +++++++++++++++++++++++++++++
security/baseband_guard_op13.h             |  50 +++++
4 files changed, 396 insertions(+)
create mode 100644 security/baseband_guard.c
create mode 100644 security/baseband_guard_op13.h

diff --git a/security/Kconfig b/security/Kconfig
index 111111111111..222222222222 100644
--- a/security/Kconfig
+++ b/security/Kconfig
@@ -367,6 +367,28 @@ config SECURITY_SAFESETID

endmenu

+config SECURITY_BASEBAND_GUARD
+	bool "Deny writes to baseband/bootloader partitions (Android)"
+	depends on SECURITY
+	default y
+	help
+	  Adds an LSM named "baseband_guard" that denies write and destructive
+	  ioctl operations (BLKDISCARD/BLKSECDISCARD/BLKZEROOUT/BLKPG) to
+	  critical partitions by /dev/block/by-name/*, with A/B suffix support.
+	  It also denies passthrough char-device ioctls to /dev/sg*, /dev/bsg/*,
+	  and /dev/nvme*, and optionally blocks whole-disk destructive operations
+	  on /dev/block/sdX, /dev/block/mmcblkN, and /dev/block/nvmeXnY.
+	  A recovery auto-allow is available.
+
+	  Runtime params (cmdline or sysfs):
+	    baseband_guard.guard_enabled=1|0
+	    baseband_guard.allow_in_recovery=1|0
+	    baseband_guard.protect_bootimg=1|0
+	    baseband_guard.block_wholedisk=1|0
+
+	  The default protected name list included here targets OnePlus 13.
+	  For other devices, replace security/baseband_guard_op13.h.
+
diff --git a/security/Makefile b/security/Makefile
index 333333333333..444444444444 100644
--- a/security/Makefile
+++ b/security/Makefile
@@ -25,3 +25,4 @@ obj-$(CONFIG_SECURITY_TOMOYO)		+= tomoyo/
obj-$(CONFIG_SECURITY_SMACK)		+= smack/
obj-$(CONFIG_SECURITY_APPARMOR)		+= apparmor/
obj-$(CONFIG_SECURITY_YAMA)		+= yama/
+obj-$(CONFIG_SECURITY_BASEBAND_GUARD)	+= baseband_guard.o
diff --git a/security/baseband_guard.c b/security/baseband_guard.c
new file mode 100644
index 000000000000..555555555555
--- /dev/null
+++ b/security/baseband_guard.c
@@ -0,0 +1,323 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * baseband_guard: deny writes/ioctls to critical baseband & bootloader partitions
+ * Target kernel: 6.6
+ */
+#include <linux/lsm_hooks.h>
+#include <linux/fs.h>
+#include <linux/dcache.h>
+#include <linux/namei.h>
+#include <linux/blkdev.h>
+#include <linux/uaccess.h>
+#include <linux/slab.h>
+#include <linux/moduleparam.h>
+#include <linux/string.h>
+
+#ifndef BLKDISCARD
+#define BLKDISCARD     _IO(0x12,119)
+#endif
+#ifndef BLKSECDISCARD
+#define BLKSECDISCARD  _IO(0x12,125)
+#endif
+#ifndef BLKZEROOUT
+#define BLKZEROOUT     _IO(0x12,127)
+#endif
+#ifndef BLKPG
+#define BLKPG          _IO(0x12,105)
+#endif
+
+/* Runtime parameters */
+static int guard_enabled = 1;         /* 1 = enabled */
+module_param(guard_enabled, int, 0644);
+MODULE_PARM_DESC(guard_enabled, "Enable baseband_guard (default=1)");
+
+static int allow_in_recovery = 1;     /* 1 = allow in recovery */
+module_param(allow_in_recovery, int, 0644);
+MODULE_PARM_DESC(allow_in_recovery, "Allow operations in recovery mode (default=1)");
+
+static int protect_bootimg = 0;       /* 1 = also protect boot/vendor_boot/dtbo */
+module_param(protect_bootimg, int, 0644);
+MODULE_PARM_DESC(protect_bootimg, "Also protect boot/vendor_boot/dtbo (default=0)");
+
+static int block_wholedisk = 1;       /* 1 = block whole-disk destructive ops */
+module_param(block_wholedisk, int, 0644);
+MODULE_PARM_DESC(block_wholedisk, "Block destructive ops on whole disks (default=1)");
+
+/* Device-specific protected names (OnePlus 13) */
+#include "baseband_guard_op13.h"
+
+/* Boot images optionally protected at runtime */
+static const char * const bootimg_names[] = {
+	"boot", "vendor_boot", "dtbo", NULL,
+};
+
+static bool bb_cmdline_is_recovery(void)
+{
+	extern const char *saved_command_line;
+	if (!saved_command_line)
+		return false;
+	return strstr(saved_command_line, "androidboot.mode=recovery") ||
+	       strstr(saved_command_line, "bootmode=recovery");
+}
+
+static bool bb_should_block(void)
+{
+	if (!guard_enabled)
+		return false;
+	if (allow_in_recovery && bb_cmdline_is_recovery())
+		return false;
+	return true;
+}
+
+/* Match by by-name/<name> and A/B suffix */
+static bool bb_match_byname(const char *path, const char *name)
+{
+	char needle[96];
+	if (!path || !name)
+		return false;
+	/* /dev/block/by-name/<name> */
+	snprintf(needle, sizeof(needle), "/by-name/%s", name);
+	if (strstr(path, needle))
+		return true;
+	/* /dev/block/by-name/<name>_a or _b */
+	snprintf(needle, sizeof(needle), "/by-name/%s_a", name);
+	if (strstr(path, needle))
+		return true;
+	snprintf(needle, sizeof(needle), "/by-name/%s_b", name);
+	if (strstr(path, needle))
+		return true;
+	return false;
+}
+
+static bool bb_match_any_protected_byname(const char *path)
+{
+	const char * const *p;
+	if (!path || !strstr(path, "/dev/block/"))
+		return false;
+	for (p = protected_names; *p; ++p) {
+		if (bb_match_byname(path, *p))
+			return true;
+	}
+	if (protect_bootimg) {
+		for (p = bootimg_names; *p; ++p) {
+			if (bb_match_byname(path, *p))
+				return true;
+		}
+	}
+	return false;
+}
+
+/* Simple detection for whole-disk device nodes by pathname */
+static bool bb_path_is_wholedisk(const char *path)
+{
+	/* sdX (no partition number), mmcblkN (no pX), nvmeXnY (no pZ) */
+	if (!path)
+		return false;
+	if (!strstr(path, "/dev/block/"))
+		return false;
+	/* crude but effective for common Android stacks */
+	/* sdX: ends with /sd[a-z] */
+	{
+		size_t len = strlen(path);
+		if (len >= 5 && !strncmp(path + len - 4, "/sd", 3)) {
+			char c = path[len - 1];
+			if (c >= 'a' && c <= 'z')
+				return true;
+		}
+	}
+	/* mmcblkN: ends with mmcblk<digits> (no 'p') */
+	if (strstr(path, "/mmcblk")) {
+		const char *mmc = strstr(path, "/mmcblk");
+		const char *tail = mmc + 7;
+		bool has_digit = false, has_p = false;
+		while (*tail && *tail != '/')
+			tail++;
+		while (*tail) {
+			if (*tail == 'p') { has_p = true; break; }
+			if (*tail >= '0' && *tail <= '9') has_digit = true;
+			tail++;
+		}
+		if (has_digit && !has_p)
+			return true;
+	}
+	/* nvmeXnY (no pZ) */
+	if (strstr(path, "/nvme")) {
+		if (strstr(path, "/nvme") && strstr(path, "n") && !strstr(path, "p"))
+			return true;
+	}
+	return false;
+}
+
+/* Passthrough char devices: sg/bsg/nvme */
+static bool bb_path_is_passthru_chr(const char *path)
+{
+	if (!path)
+		return false;
+	return strstr(path, "/dev/sg") || strstr(path, "/dev/bsg/") ||
+	       strstr(path, "/dev/nvme");
+}
+
+/* Helpers to stringify a struct path or file->f_path */
+static bool bb_get_path_str(const struct path *path, char **out_str, char **page)
+{
+	char *buf, *p;
+	if (!path || !out_str || !page)
+		return false;
+	buf = (char *)__get_free_page(GFP_KERNEL);
+	if (!buf)
+		return false;
+	p = d_path(path, buf, PAGE_SIZE);
+	if (IS_ERR(p)) {
+		free_page((unsigned long)buf);
+		return false;
+	}
+	*out_str = p;
+	*page = buf;
+	return true;
+}
+
+static bool bb_get_file_path_str(struct file *file, char **out_str, char **page)
+{
+	if (!file)
+		return false;
+	return bb_get_path_str(&file->f_path, out_str, page);
+}
+
+/* Core decision: should we deny based on the file/path and intended op? */
+static bool bb_should_deny_open_write(const struct path *path, umode_t mode)
+{
+	char *buf = NULL, *p = NULL;
+	bool deny = false;
+
+	if (!bb_should_block())
+		return false;
+
+	if (!path || !d_inode(path->dentry))
+		return false;
+
+	/* char passthru: deny open-for-write */
+	if (S_ISCHR(d_inode(path->dentry)->i_mode)) {
+		if (bb_get_path_str(path, &p, &buf)) {
+			if (bb_path_is_passthru_chr(p))
+				deny = true;
+			free_page((unsigned long)buf);
+		}
+		return deny;
+	}
+
+	/* block devices: by-name protected or whole-disk */
+	if (S_ISBLK(d_inode(path->dentry)->i_mode)) {
+		if (bb_get_path_str(path, &p, &buf)) {
+			if (bb_match_any_protected_byname(p))
+				deny = true;
+			else if (block_wholedisk && bb_path_is_wholedisk(p))
+				deny = true;
+			free_page((unsigned long)buf);
+		}
+	}
+	return deny;
+}
+
+static bool bb_should_deny_file_write(struct file *file)
+{
+	char *buf = NULL, *p = NULL;
+	bool deny = false;
+
+	if (!bb_should_block())
+		return false;
+	if (!file || !file_inode(file))
+		return false;
+
+	if (S_ISCHR(file_inode(file)->i_mode)) {
+		if (bb_get_file_path_str(file, &p, &buf)) {
+			if (bb_path_is_passthru_chr(p))
+				deny = true;
+			free_page((unsigned long)buf);
+		}
+		return deny;
+	}
+	if (S_ISBLK(file_inode(file)->i_mode)) {
+		if (bb_get_file_path_str(file, &p, &buf)) {
+			if (bb_match_any_protected_byname(p))
+				deny = true;
+			else if (block_wholedisk && bb_path_is_wholedisk(p))
+				deny = true;
+			free_page((unsigned long)buf);
+		}
+	}
+	return deny;
+}
+
+static bool bb_is_protected_ioctl_target(struct file *file)
+{
+	/* reuse the same logic as write */
+	return bb_should_deny_file_write(file);
+}
+
+/* LSM hooks */
+static int bb_path_open(struct path *path, int flags, umode_t mode)
+{
+	if ((flags & (O_WRONLY | O_RDWR)) && bb_should_deny_open_write(path, mode))
+		return -EPERM;
+	return 0;
+}
+
+static int bb_file_permission(struct file *file, int mask)
+{
+	if ((mask & MAY_WRITE) && bb_should_deny_file_write(file))
+		return -EPERM;
+	return 0;
+}
+
+static int bb_file_ioctl(struct file *file, unsigned int cmd, unsigned long arg)
+{
+	if (!bb_should_block())
+		return 0;
+	if (!file || !file_inode(file))
+		return 0;
+
+	/* For passthru char devices: deny all ioctls from user space */
+	if (S_ISCHR(file_inode(file)->i_mode)) {
+		if (bb_is_protected_ioctl_target(file))
+			return -EPERM;
+		return 0;
+	}
+
+	/* For block devices: deny destructive ioctls on protected targets */
+	if (S_ISBLK(file_inode(file)->i_mode)) {
+		if (!bb_is_protected_ioctl_target(file))
+			return 0;
+		switch (cmd) {
+		case BLKDISCARD:
+		case BLKSECDISCARD:
+		case BLKZEROOUT:
+		case BLKPG:
+			return -EPERM;
+		default:
+			break;
+		}
+	}
+	return 0;
+}
+
+static struct security_hook_list bb_hooks[] __lsm_ro_after_init = {
+	LSM_HOOK_INIT(path_open, bb_path_open),
+	LSM_HOOK_INIT(file_permission, bb_file_permission),
+	LSM_HOOK_INIT(file_ioctl, bb_file_ioctl),
+};
+
+static int __init bb_init(void)
+{
+	security_add_hooks(bb_hooks, ARRAY_SIZE(bb_hooks), "baseband_guard");
+	pr_info("baseband_guard: initialized (enabled=%d, allow_in_recovery=%d, bootimg=%d, wholedisk=%d)\n",
+		guard_enabled, allow_in_recovery, protect_bootimg, block_wholedisk);
+	return 0;
+}
+
+DEFINE_LSM(baseband_guard) = {
+	.name = "baseband_guard",
+	.init = bb_init,
+};
diff --git a/security/baseband_guard_op13.h b/security/baseband_guard_op13.h
new file mode 100644
index 000000000000..666666666666
--- /dev/null
+++ b/security/baseband_guard_op13.h
@@ -0,0 +1,50 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * OnePlus 13 (OP13) protected partition base names
+ * A/B variants are matched automatically (e.g., modem_a/_b)
+ */
+static const char * const protected_names[] = {
+	/* Baseband / NV */
+	"modem",
+	"modemst1",
+	"modemst2",
+	"fsg",
+	"fsc",
+	"bluetooth",
+	"persist",
+	"qweslicstore",
+	"oplusstanvbk",
+	"oplusdycnvbk",
+	"mdm1oemnvbktmp",
+
+	/* Bootloader / secure firmware / AVB chain */
+	"xbl",
+	"xbl_config",
+	"abl",
+	"tz",
+	"hyp",
+	"cmnlib",
+	"cmnlib64",
+	"keymaster",
+	"aop",
+	"aop_config",
+	"devcfg",
+	"qupfw",
+	"vbmeta",
+	"vbmeta_system",
+	"vbmeta_vendor",
+	"vbmeta_product",
+
+	/* UEFI-like (if present) */
+	"uefisecapp",
+	"uefivarstore",
+
+	/* NOTE:
+	 * We intentionally EXCLUDE boot/vendor_boot/dtbo by default
+	 * so kernel flashing remains possible. You can enable runtime
+	 * protection via baseband_guard.protect_bootimg=1
+	 */
+	NULL,
+};
