diff --git a/security/Kconfig b/security/Kconfig
index 3b7d2a6..c9a2f43 100644
--- a/security/Kconfig
+++ b/security/Kconfig
@@ -285,6 +285,45 @@ source "security/yama/Kconfig"
 
 endmenu
 
+config SECURITY_BASEBAND_GUARD
+    bool "Baseband/Bootloader partition write guard (LSM)"
+    help
+      Deny all writes (including BLKDISCARD/BLKZEROOUT/BLKSECDISCARD, etc.) to
+      protected partitions such as modem/baseband, bootloader and firmware
+      partitions from the normal Android userspace. This LSM is always
+      enforcing at runtime and does not create any /sys/module parameters.
+
+if SECURITY_BASEBAND_GUARD
+
+config SECURITY_BASEBAND_GUARD_ALLOW_IN_RECOVERY
+    bool "Permit writes in recovery mode"
+    default y
+    help
+      If enabled, enforcement is skipped only when booted into recovery, based
+      on androidboot.mode=recovery from the kernel cmdline.
+
+config SECURITY_BASEBAND_GUARD_PROTECT_BOOTIMG
+    bool "Also protect boot/dtbo/vbmeta/vendor_boot/init_boot/recovery"
+    default y
+    help
+      In addition to radio/firmware partitions, also protect the boot chain
+      images from being opened writable or modified via block ioctls.
+
+config SECURITY_BASEBAND_GUARD_BLOCK_WHOLEDISK
+    bool "Also block whole-disk nodes (sda, mmcblk0, dm-*)"
+    default y
+    help
+      If enabled, opening writable block devices for whole-disk nodes is denied
+      (sda, mmcblk*, nvme*, dm-*), preventing bypass via raw-disk writes.
+
+config SECURITY_BASEBAND_GUARD_VERBOSE
+    bool "Log denials to dmesg"
+    default y
+
+endif # SECURITY_BASEBAND_GUARD
+
 endmenu
 
 source "security/integrity/Kconfig"
