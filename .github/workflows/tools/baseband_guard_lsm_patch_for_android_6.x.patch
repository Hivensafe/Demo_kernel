diff --git a/security/baseband_guard.c b/security/baseband_guard.c
new file mode 100644
index 0000000..b0d6a21
--- /dev/null
+++ b/security/baseband_guard.c
@@ -0,0 +1,436 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * baseband_guard: LSM to protect critical baseband/bootloader partitions
+ * Target: Android common kernel 6.6 (sm8750)
+ *
+ * Runtime is always ENFORCING. No sysfs/module parameters are created.
+ */
+
+#include <linux/module.h>
+#include <linux/init.h>
+#include <linux/security.h>
+#include <linux/lsm_hooks.h>
+#include <linux/fs.h>
+#include <linux/namei.h>
+#include <linux/dcache.h>
+#include <linux/blkdev.h>
+#include <linux/blk_types.h>
+#include <linux/cred.h>
+#include <linux/limits.h>
+#include <linux/string.h>
+#include <linux/printk.h>
+#include <linux/errno.h>
+#include <linux/version.h>
+
+extern const char *saved_command_line; /* from init/main.c */
+
+/* Compile-time policy (no runtime knobs) */
+#define BB_ENFORCING                 1
+#ifdef CONFIG_SECURITY_BASEBAND_GUARD_ALLOW_IN_RECOVERY
+#define BB_ALLOW_IN_RECOVERY         1
+#else
+#define BB_ALLOW_IN_RECOVERY         0
+#endif
+#ifdef CONFIG_SECURITY_BASEBAND_GUARD_PROTECT_BOOTIMG
+#define BB_PROTECT_BOOTIMG           1
+#else
+#define BB_PROTECT_BOOTIMG           0
+#endif
+#ifdef CONFIG_SECURITY_BASEBAND_GUARD_BLOCK_WHOLEDISK
+#define BB_BLOCK_WHOLEDISK           1
+#else
+#define BB_BLOCK_WHOLEDISK           0
+#endif
+#ifdef CONFIG_SECURITY_BASEBAND_GUARD_VERBOSE
+#define BB_VERBOSE                   1
+#else
+#define BB_VERBOSE                   0
+#endif
+
+/* Common Qualcomm sm8750 sensitive partitions */
+static const char * const qcom_core_parts[] = {
+    /* baseband + calibration */
+    "modem","modemst1","modemst2","fsg","fsc","bluetooth",
+    "dsp","cdsp","qweslicstore","qweslicstorebak",
+    /* boot chain / firmware */
+    "xbl","xbl_config","abl","tz","hyp","cmnlib","cmnlib64",
+    "keymaster","devcfg","uefisecapp","qupfw","featenabler",
+    "vbmeta","vbmeta_system","vbmeta_vendor","vbmeta_system_ext",
+    /* misc binding */
+    "keystore","rpm","rpmfw","uefi","spunvm","apdp","msadp",
+};
+
+static const char * const bootimg_parts[] = {
+    "boot","dtbo","vendor_boot","init_boot","recovery"
+};
+
+/* Whole-disk device name prefixes (gendisk->disk_name) */
+static const char * const wholedisk_prefixes[] = { "sda", "sdb", "mmcblk", "nvme", "dm-" };
+
+static bool in_recovery_mode(void)
+{
+#if BB_ALLOW_IN_RECOVERY
+    if (!saved_command_line)
+        return false;
+    if (strstr(saved_command_line, "androidboot.mode=recovery"))
+        return true;
+    if (strstr(saved_command_line, "skip_initramfs=1") && strstr(saved_command_line, "recovery"))
+        return true;
+#endif
+    return false;
+}
+
+static bool is_write_flags(unsigned int fmode)
+{
+    return (fmode & FMODE_WRITE) || (fmode & FMODE_APPEND);
+}
+
+static bool is_protected_byname(const char *path)
+{
+    size_t i;
+    const char *base;
+    if (!path)
+        return false;
+
+    base = strrchr(path, '/');
+    base = base ? base + 1 : path;
+
+    /* quick path: by-name symlinks */
+    if (strstr(path, "/by-name/")) {
+        for (i = 0; i < ARRAY_SIZE(qcom_core_parts); i++)
+            if (!strcmp(base, qcom_core_parts[i]))
+                return true;
+#if BB_PROTECT_BOOTIMG
+        for (i = 0; i < ARRAY_SIZE(bootimg_parts); i++)
+            if (!strcmp(base, bootimg_parts[i]))
+                return true;
+#endif
+    }
+    return false;
+}
+
+static bool is_wholedisk(struct block_device *bdev)
+{
+    size_t i;
+    const char *dn;
+    if (!bdev || !bdev->bd_disk)
+        return false;
+    dn = bdev->bd_disk->disk_name;
+    if (!dn)
+        return false;
+    for (i = 0; i < ARRAY_SIZE(wholedisk_prefixes); i++)
+        if (!strncmp(dn, wholedisk_prefixes[i], strlen(wholedisk_prefixes[i])))
+            return true;
+    return false;
+}
+
+static int deny(const char *why)
+{
+    if (!BB_ENFORCING)
+        return 0;
+    if (BB_ALLOW_IN_RECOVERY && in_recovery_mode())
+        return 0;
+#if BB_VERBOSE
+    pr_info("baseband_guard: deny %s pid=%d comm=%s
", why, current->pid, current->comm);
+#endif
+    return -EPERM;
+}
+
+static int bb_file_open(struct file *file)
+{
+    char *tmp = NULL;
+    char *path = NULL;
+    int rc = 0;
+    struct inode *inode;
+    struct block_device *bdev;
+
+    if (!file)
+        return 0;
+    inode = file_inode(file);
+
+    /* Only care about block devices opened writable */
+    if (!S_ISBLK(inode->i_mode) || !is_write_flags(file->f_mode))
+        return 0;
+
+    /* Whole-disk guard */
+    bdev = I_BDEV(inode);
+#if BB_BLOCK_WHOLEDISK
+    if (is_wholedisk(bdev))
+        return deny("open wholedisk writable");
+#endif
+
+    tmp = (char *)__get_free_page(GFP_KERNEL);
+    if (!tmp)
+        return 0; /* fail-open if memory constrained */
+    path = d_path(&file->f_path, tmp, PAGE_SIZE);
+    if (IS_ERR(path))
+        goto out;
+
+    if (is_protected_byname(path))
+        rc = deny("open protected by-name writable");
+
+out:
+    free_page((unsigned long)tmp);
+    return rc;
+}
+
+/* Block destructive ioctls even if someone opened read-only but issues ioctl */
+static bool is_destructive_ioctl(unsigned int cmd)
+{
+    switch (cmd) {
+    case BLKDISCARD:
+    case BLKSECDISCARD:
+    case BLKZEROOUT:
+#ifdef BLKDISCARDZEROES
+    case BLKDISCARDZEROES:
+#endif
+    case BLKPG:
+    case BLKTRIM:
+    case BLKRESETZONE:
+    case BLKOPENZONE:
+    case BLKCLOSEZONE:
+    case BLKRMZGROUP:
+    case BLKSETRO:
+    case BLKROSET:
+    case BLKSETBADSECTORS:
+    case BLKRRPART:
+        return true;
+    default:
+        return false;
+    }
+}
+
+static int bb_file_ioctl(struct file *file, unsigned int cmd, unsigned long arg)
+{
+    if (is_destructive_ioctl(cmd))
+        return deny("destructive ioctl");
+    return 0;
+}
+
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6,6,0)
+static int bb_file_ioctl_compat(struct file *file, unsigned int cmd, unsigned long arg)
+{
+    return bb_file_ioctl(file, cmd, arg);
+}
+#endif
+
+static struct security_hook_list bb_hooks[] __lsm_ro_after_init = {
+    LSM_HOOK_INIT(file_open, bb_file_open),
+    LSM_HOOK_INIT(file_ioctl, bb_file_ioctl),
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6,6,0)
+    LSM_HOOK_INIT(file_ioctl_compat, bb_file_ioctl_compat),
+#endif
+};
+
+static int __init bb_init(void)
+{
+    security_add_hooks(bb_hooks, ARRAY_SIZE(bb_hooks), "baseband_guard");
+#if BB_VERBOSE
+    pr_info("baseband_guard: initialized (always ENFORCING), allow_in_recovery=%d, block_wholedisk=%d
",
+        (int)BB_ALLOW_IN_RECOVERY, (int)BB_BLOCK_WHOLEDISK);
+#endif
+    return 0;
+}
+
+DEFINE_LSM(baseband_guard) = {
+    .name = "baseband_guard",
+    .init = bb_init,
+};
+
+MODULE_DESCRIPTION("LSM to guard baseband/bootloader partitions (no runtime knobs)");
+MODULE_AUTHOR("秋刀鱼");
+MODULE_LICENSE("GPL v2");
